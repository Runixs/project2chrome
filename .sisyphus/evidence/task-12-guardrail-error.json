  "guardrailContract": {
    "validateManagedKey_returns": "{ eligible: false, reason: 'skipped_unmanaged' } for unmanaged keys",
    "checkAmbiguity_returns": "{ eligible: false, reason: 'skipped_ambiguous' } for out-of-bounds indices",
    "noWriteOccurs": "Guaranteed — all writes are gated after guardrail eligibility checks pass",
