{
  "task": "T3",
  "scenario": "POST /reverse-sync error cases",
  "date": "2026-02-25",
  "verified_by": "reverse-endpoint.test.ts (node:test)",
  "error_cases": [
    {
      "case": "wrong token",
      "request": {
        "method": "POST",
        "path": "/reverse-sync",
        "headers": { "X-Project2Chrome-Token": "bad-token" }
      },
      "response": { "status": 401, "body": { "error": "unauthorized" } },
      "side_effect": "processedBatchIds unchanged (no mutation)"
    },
    {
      "case": "missing token",
      "request": {
        "method": "POST",
        "path": "/reverse-sync",
        "headers": {}
      },
      "response": { "status": 401, "body": { "error": "unauthorized" } }
    },
    {
      "case": "malformed JSON body",
      "request": {
        "method": "POST",
        "path": "/reverse-sync",
        "headers": { "X-Project2Chrome-Token": "<valid-token>" },
        "raw_body": "{ not valid json ["
      },
      "response": { "status": 400, "body": { "error": "malformed JSON" } }
    },
    {
      "case": "missing events array",
      "request": {
        "method": "POST",
        "path": "/reverse-sync",
        "headers": { "X-Project2Chrome-Token": "<valid-token>" },
        "body": {
          "batchId": "batch-no-events",
          "sentAt": "2026-02-25T10:00:00.000Z"
        }
      },
      "response": { "status": 400, "body": { "error": "invalid batch" } }
    },
    {
      "case": "event missing required fields",
      "request": {
        "method": "POST",
        "path": "/reverse-sync",
        "headers": { "X-Project2Chrome-Token": "<valid-token>" },
        "body": {
          "batchId": "batch-bad-event",
          "sentAt": "2026-02-25T10:00:00.000Z",
          "events": [{ "type": "bookmark_created" }]
        }
      },
      "response": { "status": 400, "body": { "error": "invalid batch" } }
    },
    {
      "case": "GET /payload without token",
      "request": { "method": "GET", "path": "/payload", "headers": {} },
      "response": { "status": 401, "body": { "error": "unauthorized" } }
    }
  ]
}
